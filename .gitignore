# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
build/
dist/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/

# Notebooks exportados (auxiliares, regenerables con scripts/export_notebooks.py)
outputs/exports/

# ============================================================
# Datasets - NUNCA subir imagenes al repo (tamano)
# ============================================================

# Recoleccion compartida del curso (~9515 imgs, 3.3 GB)
Fruits/
Fruits.zip

# Cualquier zip pesado en la raiz
*.zip
*.tar
*.tar.gz
*.7z
*.rar

# Datos crudos y procesados (incluye descarga Kaggle via kagglehub)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Carpeta de annotations: solo se versiona manifest.csv + README.md
data/annotations/*
!data/annotations/.gitkeep
!data/annotations/manifest.csv
!data/annotations/*.md

# ============================================================
# Modelos entrenados y experimentos
# ============================================================
experiments/checkpoints/*
!experiments/checkpoints/.gitkeep

experiments/logs/*
!experiments/logs/.gitkeep

experiments/results/*.pkl
experiments/results/*.h5
experiments/results/*.pt
experiments/results/*.npy

# JSON de umbrales de tamano (regenerable por la app Streamlit en primera ejecucion)
experiments/size_thresholds.json

# Compatibilidad con scaffold viejo (por si alguien crea models/)
models/*.pkl
models/*.h5
models/*.pt
!models/.gitkeep

# ============================================================
# Outputs
# ============================================================
# Figuras vectoriales SI se versionan (requeridas para informe IEEE)
# outputs/figures/*.svg  <- NO ignorado, se sube
outputs/*.tmp
outputs/cache/

# ============================================================
# Imagenes auxiliares para informe / video (no versionar)
# ============================================================
imagenes_ComparativaModelos/
imagenes_informe/
imagenes_video/

# Imagenes sueltas en la raiz (screenshots para informe/demo)
/*.png
/*.jpg
/*.jpeg
/*.webp
/*.gif

# ============================================================
# Credenciales y secretos
# ============================================================
.env
.env.local
*.pem
*.key
kaggle.json
.kaggle/

# ============================================================
# Cache de descarga (kagglehub guarda fuera del repo, pero por si acaso)
# ============================================================
.cache/
*.lock

